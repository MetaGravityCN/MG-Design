{
  "name": "mg-design",
  "version": "0.0.1",
  "private": true,
  "description": "MG Design System - An independent Vue 3 component library published under @metagravity_cn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaGravityCN/MG-Design.git"
  },
  "homepage": "https://github.com/MetaGravityCN/MG-Design#readme",
  "bugs": {
    "url": "https://github.com/MetaGravityCN/MG-Design/issues"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:core": "npm --prefix packages/theme run build && npm --prefix packages/icons run build && npm --prefix packages/utils run build && npm --prefix packages/primitives run build && npm --prefix packages/components run build",
    "build:business": "npm --prefix packages/business run build",
    "build:all": "npm run build:core && npm run build:business",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:element-boundary": "node scripts/check-element-boundary.mjs",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:all && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@types/node": "^22.15.14",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.1.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "sass": "^1.88.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
